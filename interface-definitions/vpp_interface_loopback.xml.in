<?xml version="1.0"?>
<interfaceDefinition>
  <node name='interfaces'>
    <children>
      <node name='vpp'>
        <children>
          <tagNode name="loopback" owner="${vyos_conf_scripts_dir}/vpp_interfaces_loopback.py">
            <properties>
              <priority>325</priority>
              <help>Loopback Interface</help>
              <constraint>
                <regex>vpplo[0-9]+</regex>
              </constraint>
              <constraintErrorMessage>Loopback interface must be named vpploN</constraintErrorMessage>
              <valueHelp>
                <format>vpploN</format>
                <description>Loopback interface name</description>
              </valueHelp>
            </properties>
            <children>
              #include <include/generic-description.xml.i>
              #include <include/interface/disable.xml.i>
              #include <include/interface/address-ipv4-ipv6.xml.i>
              #include <include/interface/mtu-68-16000.xml.i>
              #include <include/vpp/vif.xml.i>
            </children>
          </tagNode>
        </children>
      </node>
    </children>
  </node>
</interfaceDefinition>
